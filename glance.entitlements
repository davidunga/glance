<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <true/>
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!--
        WKWebView's WebContent process needs network.client to initialize
        XPC connections to system services (pasteboard, etc.) — without this,
        the renderbox precondition fails and the view shows blank content,
        even when loading purely local HTML.
    -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!--
        Markdown files reference images, stylesheets, etc. via relative
        paths. The sandbox only grants access to the specific file the
        user opened, so without broader read access the viewer cannot
        load those sibling assets. This temporary exception is fine for
        a locally-signed app (not App Store).
    -->
    <key>com.apple.security.temporary-exception.files.absolute-path.read-only</key>
    <array>
        <string>/</string>
    </array>
    <!--
        The in-app updater replaces /Applications/Glance.app with a newly
        downloaded bundle. Child processes we spawn (e.g. the detached
        installer shell script) inherit our sandbox, so they need this
        write exception to mutate the install path.
    -->
    <key>com.apple.security.temporary-exception.files.absolute-path.read-write</key>
    <array>
        <string>/Applications/</string>
    </array>
</dict>
</plist>
